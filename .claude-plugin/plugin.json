{
  "name": "better-godot-mcp",
  "description": "Comprehensive Godot Engine integration — 18 tools for game development",
  "version": "1.7.0",
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/better-godot-mcp",
  "mcpServers": {
    "better-godot-mcp": {
      "command": "npx",
      "args": ["-y", "@n24q02m/better-godot-mcp"],
      "env": {
        "GODOT_PATH": "",
        "GODOT_PROJECT_PATH": ""
      }
    },
    "better-godot-mcp-bunx": {
      "command": "bunx",
      "args": ["--bun", "@n24q02m/better-godot-mcp"],
      "env": {
        "GODOT_PATH": "",
        "GODOT_PROJECT_PATH": ""
      }
    },
    "better-godot-mcp-pnpx": {
      "command": "pnpx",
      "args": ["@n24q02m/better-godot-mcp"],
      "env": {
        "GODOT_PATH": "",
        "GODOT_PROJECT_PATH": ""
      }
    },
    "better-godot-mcp-yarn": {
      "command": "yarn",
      "args": ["dlx", "@n24q02m/better-godot-mcp"],
      "env": {
        "GODOT_PATH": "",
        "GODOT_PROJECT_PATH": ""
      }
    },
    "better-godot-mcp-docker": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "-v", ".:/project", "n24q02m/better-godot-mcp:latest"],
      "env": {
        "GODOT_PATH": "",
        "GODOT_PROJECT_PATH": "/project"
      }
    }
  },
  "skills": "./skills/"
}
